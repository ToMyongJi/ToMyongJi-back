# ================================================================
# ToMyongJi 로컬 개발 환경 변수 템플릿 (Claude Code 전용)
# ================================================================
# 사용 방법:
#   1. 이 파일을 `.env`로 복사합니다: cp .env.example .env
#   2. 각 변수에 실제 값을 채워 넣습니다.
#   3. `.env` 파일은 절대 Git에 커밋하지 않습니다 (이미 .gitignore에 등록됨).
#
# Claude Code가 서버 가동 / DB 접근 시 이 파일을 참조합니다:
#   Invoke-Expression (python .claude/skills/local-dev/scripts/env_loader.py)
# ================================================================

# ----------------------------------------------------------------
# [DB] MySQL 접속 정보
# ----------------------------------------------------------------
# SSH 터널 사용 시: localhost:3307 (ssh_tunnel.py로 터널 먼저 열 것)
DB_URL=jdbc:mysql://localhost:3307/tomyongjiTest?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=

# ----------------------------------------------------------------
# [JWT] 인증 시크릿
# ----------------------------------------------------------------
JWT_SECRET=

# ----------------------------------------------------------------
# [OCR] NAVER Cloud OCR API
# ----------------------------------------------------------------
OCR_API_URL=
OCR_SECRET_KEY=

# ----------------------------------------------------------------
# [MAIL] Gmail SMTP
# ----------------------------------------------------------------
MAIL_USERNAME=
MAIL_PASSWORD=

# ----------------------------------------------------------------
# [REDIS] 캐시 서버
# ----------------------------------------------------------------
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
